{
	"name": "@checkpoint/core",
	"version": "0.1.0",
	"description": "Agent-neutral shared checkpoint core: git facts, markdown checkpoint format, opt-in config, archive prune, skip-empty/dedup, startup pending-count.",
	"license": "MIT",
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"default": "./dist/index.js"
		}
	},
	"files": [
		"dist"
	],
	"engines": {
		"node": ">=18"
	},
	"scripts": {
		"build": "tsc -p tsconfig.json",
		"typecheck": "tsc -p tsconfig.json --noEmit",
		"test": "node --import tsx --test \"tests/*.test.ts\"",
		"format": "prettier --write .",
		"lint": "prettier --check ."
	},
	"devDependencies": {
		"@types/node": "^22.20.0",
		"prettier": "^3.3.3",
		"tsx": "^4.19.2",
		"typescript": "^5.6.3"
	}
}
