{
	"name": "@checkpoint/claude-code",
	"version": "0.1.0",
	"description": "Claude Code adapter for checkpoint: thin plugin (slash commands + lifecycle hooks) wrapping @checkpoint/core.",
	"license": "MIT",
	"type": "module",
	"engines": {
		"node": ">=18"
	},
	"scripts": {
		"build": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\" && esbuild src/index.ts --bundle --platform=node --format=esm --target=node20 --outfile=dist/index.js",
		"typecheck": "tsc -p tsconfig.json --noEmit",
		"test": "node --import tsx --test \"tests/*.test.ts\"",
		"format": "prettier --write .",
		"lint": "prettier --check ."
	},
	"dependencies": {
		"@checkpoint/core": "file:../../core"
	},
	"devDependencies": {
		"@types/node": "^22.20.0",
		"esbuild": "^0.24.0",
		"prettier": "^3.3.3",
		"tsx": "^4.19.2",
		"typescript": "^5.6.3"
	}
}
