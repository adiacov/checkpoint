{
	"hooks": {
		"SessionStart": [
			{
				"hooks": [
					{
						"type": "command",
						"command": "node",
						"args": ["${CLAUDE_PLUGIN_ROOT}/dist/index.js", "session-start"]
					}
				]
			}
		],
		"SessionEnd": [
			{
				"hooks": [
					{
						"type": "command",
						"command": "node",
						"args": ["${CLAUDE_PLUGIN_ROOT}/dist/index.js", "session-end"]
					}
				]
			}
		],
		"PreCompact": [
			{
				"hooks": [
					{
						"type": "command",
						"command": "node",
						"args": ["${CLAUDE_PLUGIN_ROOT}/dist/index.js", "pre-compact"]
					}
				]
			}
		]
	}
}
