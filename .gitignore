.DS_Store
.env
.env.*
*.log

# Node build artifacts
node_modules/
dist/

# Agent Workspace legacy local cache
.agent/

# Per-machine install manifest (006 install/distribution)
.install/

# Agent Workspace sync working files (baseline snapshots + transient artifacts)
.agent-workspace/baseline/
*.bak
*.merge

# Transient handoff outbox (delivered downstream, not project history)
HANDOFF.md

# Local/private identity, memory, or secrets
MEMORY.md
DECISIONS.local.md
LOCAL.md
PRIVATE.md
secrets/
*.pem
*.key

# Raw checkpoint captures — transient session evidence (git state + verbatim recent
# conversation). Never publish: may contain secrets, tokens, and local absolute paths.
# Ignore all content but keep the empty dir structure (.gitkeep) so opt-in stays no-op here.
sessions/pending/*
sessions/archive/*
!sessions/pending/.gitkeep
!sessions/archive/.gitkeep
